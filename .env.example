# Email (already working)
RESEND_API_KEY=
CONTACT_TO=owner@archetypeoriginal.com
CONTACT_FROM=Archetype Original <no-reply@archetypeoriginal.com>

# /app (future integrations)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ALI Deletions (Super Admin). See notes/ALI_DELETIONS_ENV.md.
# ALLOW_ALI_DELETIONS=true
# ALLOW_ALI_FULL_WIPE=true
# ALI_WIPE_IDS=
# ALI_WIPE_NAMES=
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
CALENDLY_LINK=
TIMEZONE=America/Chicago

# AO Automation Dashboard (single-owner magic link). Must match the email allowed to sign in.
# AO_OWNER_EMAIL=

# AO Social (scheduling + publishing). See notes/SOCIAL_VERCEL_ENV.md.
# SOCIAL_POST_SECRET=
# CRON_SECRET=
# LINKEDIN_ACCESS_TOKEN=
# LINKEDIN_PERSON_URN=
# LINKEDIN_PAGE_1_ACCESS_TOKEN=
# LINKEDIN_PAGE_1_URN=
# FACEBOOK_PAGE_1_ACCESS_TOKEN=
# FACEBOOK_PAGE_1_PAGE_ID=
# FACEBOOK_GROUP_1_ACCESS_TOKEN=
# FACEBOOK_GROUP_1_GROUP_ID=
# INSTAGRAM_ACCOUNT_1_ACCESS_TOKEN=
# INSTAGRAM_ACCOUNT_1_IG_USER_ID=
# TWITTER_API_KEY=
# TWITTER_API_SECRET=
# TWITTER_ACCESS_TOKEN=
# TWITTER_ACCESS_TOKEN_SECRET=

# Operators — short private testing only (bakes in at build; remove and redeploy when done).
# VITE_OPERATORS_AUTH_BYPASS=true
# VITE_OPERATORS_BYPASS_EMAIL=you@example.com
# Optional: bypass stops after this instant (ISO 8601) so you do not have to redeploy to turn it off
# VITE_OPERATORS_BYPASS_UNTIL=2026-05-04T18:30:00.000Z

# Operators aggregate dashboard (who may open system-wide metrics). Default in code is bart@archetypeoriginal.com only.
# Optional overrides — use the same value on the server and in VITE_* when you change them:
# OPERATORS_DASHBOARD_ALLOWED_EMAILS=bart@archetypeoriginal.com,ops@example.com
# VITE_OPERATORS_DASHBOARD_ALLOWED_EMAILS=bart@archetypeoriginal.com,ops@example.com
# Restore staff-role access (Chief Operator / Accountant / Super Admin) instead of email list:
# OPERATORS_DASHBOARD_ALLOWED_EMAILS=ROLE_BASED
# VITE_OPERATORS_DASHBOARD_ALLOWED_EMAILS=ROLE_BASED
